# ===========================================
# Hermod - Environment Configuration
# Swift messenger of your data
# ===========================================

# Database (required)
DATABASE_URL="postgresql://hermod:hermod@localhost:5432/hermod"

# NextAuth (required)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Google OAuth (required)
# Get these at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Email delivery is configured per-user in the UI (Connections → Add → SMTP Email)

# Encryption (required for connection password encryption)
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=""

# SFTP (optional, for file integrations)
# Docker SFTP server runs on port 2222
SFTP_HOST="localhost"
SFTP_PORT="2222"

# LLM Provider (optional, for Mjolnir AI analysis)
# Supported: openai, xai, groq, together, fireworks, anthropic
LLM_PROVIDER=""
LLM_MODEL=""
LLM_API_KEY=""
LLM_BASE_URL=""

# AI Router — local GPU primary, Anthropic fallback (optional)
# Local Ollama GPU for free inference (gemma4:31b always hot)
OLLAMA_URL="http://192.168.1.181:11434"
OLLAMA_MODEL="gemma4:31b"
# Anthropic API — fallback when local GPU is down
ANTHROPIC_API_KEY=""


# Stripe (required for paid tiers)
# Create products at https://dashboard.stripe.com/products
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_THOR="price_..."
STRIPE_PRICE_ODIN="price_..."