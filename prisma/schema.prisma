generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth ────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  ext_expires_in Int?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id               String             @id @default(cuid())
  name             String?
  email            String?            @unique
  emailVerified    DateTime?
  image            String?
  accounts         Account[]
  sessions         Session[]
  reports          Report[]
  sftpConnections  SftpConnection[]
  emailConnections EmailConnection[]
  blueprints       Blueprint[]
  bifrostRoutes    BifrostRoute[]
  connections      Connection[]

  // Multi-tenant
  memberships      TenantMembership[]
  activeTenantId   String?
  activeTenant     Tenant?            @relation("ActiveTenant", fields: [activeTenantId], references: [id], onDelete: SetNull)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Multi-Tenant ───────────────────────────────────

enum UserRole {
  OWNER
  ADMIN
  USER
  ANALYTICS
  BILLING
  API_SERVICE
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

model Tenant {
  id               String             @id @default(cuid())
  name             String
  slug             String             @unique
  domain           String?            @unique
  logoUrl          String?

  // Subscription
  plan                     String             @default("heimdall")
  planExpiresAt            DateTime?
  stripeCustomerId         String?            @unique
  stripeSubscriptionId     String?            @unique
  stripePriceId            String?
  stripeCurrentPeriodEnd   DateTime?

  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  // Relations
  memberships      TenantMembership[]
  invitations      Invitation[]
  activeUsers      User[]             @relation("ActiveTenant")

  // Tenant-scoped data
  reports           Report[]
  connections       Connection[]
  connectionFolders ConnectionFolder[]
  bifrostRoutes     BifrostRoute[]
  forgeBlueprints   ForgeBlueprint[]
  sftpConnections   SftpConnection[]
  emailConnections  EmailConnection[]

  // Realm Gates
  realmGates        RealmGate[]
  gatePushes        GatePush[]

  // Raven (on-prem agents)
  ravenApiKeys      RavenApiKey[]
  ravenSatellites   RavenSatellite[]
}

model TenantMembership {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String
  role      UserRole @default(USER)

  invitedBy String?
  joinedAt  DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@index([tenantId])
  @@index([userId])
}

model Invitation {
  id        String           @id @default(cuid())
  tenantId  String
  email     String
  role      UserRole         @default(USER)
  status    InvitationStatus @default(PENDING)

  invitedBy String
  token     String           @unique @default(cuid())

  expiresAt DateTime
  createdAt DateTime         @default(now())

  tenant    Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([tenantId])
  @@index([token])
}

// ─── SFTP Connections ────────────────────────────────

model SftpConnection {
  id                 String            @id @default(cuid())
  name               String
  description        String?
  sourceType         SftpSourceType
  sftpHost           String            @default("localhost")
  sftpPort           Int               @default(2222)
  sftpUsername        String            @unique
  sftpPassword        String            // Encrypted at rest with AES-256-GCM
  fileFormat         FileFormat        @default(CSV)
  bqDataset          String
  bqTable            String
  loadMode           LoadMode          @default(REPLACE)
  notificationEmails String[]
  status             SftpStatus        @default(ACTIVE)
  lastFileAt         DateTime?
  lastFileName       String?
  filesProcessed     Int               @default(0)
  userId             String
  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantId           String?
  tenant             Tenant?           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@index([tenantId])
}

enum SftpSourceType {
  ADP
  QUICKBOOKS
  SAP
  GENERIC_FILE
  CUSTOM_SFTP
}

enum FileFormat {
  CSV
  TSV
  XLSX
}

enum LoadMode {
  APPEND
  REPLACE
}

enum SftpStatus {
  ACTIVE
  ERROR
  DISABLED
}

// ─── Email Connections ─────────────────────────────────

enum EmailAuthType {
  NONE      // IP-whitelisted relay, no credentials
  PLAIN     // Username + password (app passwords, basic SMTP)
  OAUTH2    // Client ID + secret + refresh token
}

model EmailConnection {
  id          String        @id @default(cuid())
  name        String
  host        String
  port        Int           @default(587)
  secure      Boolean       @default(false)
  authType    EmailAuthType @default(PLAIN)
  username    String?
  password    String?       // Encrypted at rest (AES-256-GCM)
  fromAddress String
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantId    String?
  tenant      Tenant?       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  schedules   Schedule[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([tenantId])
}

// ─── Reports ─────────────────────────────────────────

model Report {
  id           String     @id @default(cuid())
  name         String
  description  String?
  sqlQuery     String     @db.Text
  formatting   Json?      // SheetTemplate: Univer cosmetics (styles, merges, freeze)
  columnConfig Json?      // ColumnConfig[]: column mapping, order, display names, formulas
  connectionId String
  connection   Connection @relation(fields: [connectionId], references: [id], onDelete: Restrict)
  blueprintId  String?
  blueprint    Blueprint? @relation(fields: [blueprintId], references: [id], onDelete: SetNull)
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantId     String?
  tenant       Tenant?    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  schedule     Schedule?
  runHistory   RunLog[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([tenantId])
}

// ─── Schedules ───────────────────────────────────────

model Schedule {
  id                String           @id @default(cuid())
  reportId          String           @unique
  report            Report           @relation(fields: [reportId], references: [id], onDelete: Cascade)
  enabled           Boolean          @default(true)
  frequency         ScheduleFrequency
  daysOfWeek        Int[]            // 0=Sun, 1=Mon, ... 6=Sat
  dayOfMonth        Int?             // 1-31 for monthly
  timeHour          Int              // 0-23
  timeMinute        Int              // 0-59
  timezone          String           @default("America/Chicago")
  emailSubject      String           @default("{report_name} — {date}")
  emailBody         String           @db.Text @default("")
  monthsOfYear      Int[]            // For quarterly: which months (1-12)
  emailConnectionId String?
  emailConnection   EmailConnection? @relation(fields: [emailConnectionId], references: [id], onDelete: SetNull)
  recipients        Recipient[]
  nextRunAt         DateTime?
  pgBossJobId       String?          // pg-boss job reference
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([enabled, nextRunAt])
}

enum ScheduleFrequency {
  EVERY_15_MIN
  EVERY_30_MIN
  HOURLY
  EVERY_4_HOURS
  EVERY_12_HOURS
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
  QUARTERLY
}

// ─── Recipients ──────────────────────────────────────

model Recipient {
  id         String   @id @default(cuid())
  email      String
  name       String?
  scheduleId String
  schedule   Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
}

// ─── Run History ─────────────────────────────────────

model RunLog {
  id         String    @id @default(cuid())
  reportId   String
  report     Report    @relation(fields: [reportId], references: [id], onDelete: Cascade)
  status     RunStatus
  rowCount   Int?
  error      String?   @db.Text
  startedAt  DateTime  @default(now())
  completedAt DateTime?

  @@index([reportId, status])
  @@index([startedAt])
}

enum RunStatus {
  RUNNING
  SUCCESS
  FAILED
}

// ─── Blueprints (Mjolnir) ────────────────────────────

model Blueprint {
  id              String          @id @default(cuid())
  name            String
  description     String?
  version         Int             @default(1)
  steps           Json            // ForgeStep[] — the transformation pipeline
  sourceSchema    Json?           // Expected input columns + types (for validation)
  analysisLog     Json?           // Full Mjolnir analysis results (audit trail)
  afterFormatting Json?           // BlueprintFormatting — captured AFTER workbook styles for pixel-perfect mirror
  beforeSample    String?         // Original BEFORE filename
  afterSample     String?         // Original AFTER filename
  status          BlueprintStatus @default(DRAFT)
  userId          String
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  reports         Report[]
  bifrostRoutes   BifrostRoute[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

enum BlueprintStatus {
  DRAFT
  VALIDATED
  ACTIVE
  ARCHIVED
}

// ─── Blueprint Version Control ──────────────────────────

model ForgeBlueprint {
  id              String                    @id @default(cuid())
  routeId         String                    @unique
  route           BifrostRoute              @relation("forgeBlueprint", fields: [routeId], references: [id], onDelete: Cascade)
  name            String
  description     String?
  currentVersion  Int                       @default(1)
  status          ForgeBlueprintStatus      @default(ACTIVE)
  tenantId        String?
  tenant          Tenant?                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt
  createdBy       String?

  versions        ForgeBlueprintVersion[]
  executions      ForgeBlueprintExecution[]
  realmGates      RealmGate[]

  @@index([tenantId])
}

model ForgeBlueprintVersion {
  id              String                    @id @default(cuid())
  blueprintId     String
  blueprint       ForgeBlueprint            @relation(fields: [blueprintId], references: [id], onDelete: Cascade)
  version         Int

  steps           Json                      // ForgeStep[] with stepId
  stepsHash       String                    // SHA-256 of normalized steps

  source          VersionSource             @default(FORGE)
  beforeFileHash  String?
  afterFileHash   String?
  aiModelUsed     String?
  aiConfidence    Float?

  changeReason    String?
  changeSummary   Json?

  isLocked        Boolean                   @default(false)
  lockedAt        DateTime?
  lockedBy        String?

  createdAt       DateTime                  @default(now())
  createdBy       String?

  executions      ForgeBlueprintExecution[]

  @@unique([blueprintId, version])
  @@index([blueprintId])
}

model ForgeBlueprintExecution {
  id              String                    @id @default(cuid())
  blueprintId     String
  blueprint       ForgeBlueprint            @relation(fields: [blueprintId], references: [id])
  versionId       String?
  version         ForgeBlueprintVersion?    @relation(fields: [versionId], references: [id], onDelete: SetNull)
  versionNumber   Int

  jobId           String?
  routeRunId      String?
  status          ExecutionStatus           @default(RUNNING)

  inputRowCount   Int?
  outputRowCount  Int?
  inputHash       String?
  outputHash      String?

  startedAt       DateTime                  @default(now())
  completedAt     DateTime?
  durationMs      Int?

  errorMessage    String?
  errorStep       Int?

  @@index([blueprintId])
  @@index([versionId])
  @@index([startedAt])
}

enum ForgeBlueprintStatus {
  ACTIVE
  ARCHIVED
  DRAFT
}

enum VersionSource {
  FORGE
  MANUAL_EDIT
  ROLLBACK
  IMPORT
}

enum ExecutionStatus {
  RUNNING
  SUCCESS
  FAILED
  CANCELLED
}

// ─── Unified Connections ──────────────────────────────

enum ConnectionType {
  POSTGRES
  MSSQL
  MYSQL
  BIGQUERY
  NETSUITE
  SFTP
  REST_API
  CSV_FILE
  EXCEL_FILE
  GOOGLE_SHEETS
}

enum ConnectionStatus {
  ACTIVE
  ERROR
  DISABLED
}

model Connection {
  id             String           @id @default(cuid())
  name           String
  type           ConnectionType
  config         Json
  credentials    String?          @db.Text  // Encrypted JSON: passwords, tokens, service account keys
  status         ConnectionStatus @default(ACTIVE)
  lastTestedAt   DateTime?
  userId         String
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantId       String?
  tenant         Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  folderId       String?
  folder         ConnectionFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  reports        Report[]
  fileEntries    FileEntry[]
  routesAsSource BifrostRoute[] @relation("routeSource")
  routesAsDest   BifrostRoute[] @relation("routeDest")
  realmGates     RealmGate[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([tenantId])
  @@index([folderId])
}

// ─── Connection Folders ──────────────────────────────

model ConnectionFolder {
  id          String       @id @default(cuid())
  name        String
  color       String       @default("#d4af37")
  icon        String?
  sortOrder   Int          @default(0)
  tenantId    String
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  connections Connection[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([tenantId])
  @@index([tenantId, sortOrder])
}

// ─── File Entries (Jötunheim) ────────────────────────

model FileEntry {
  id            String          @id @default(cuid())
  connectionId  String
  connection    Connection      @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  fileName      String
  fileSize      Int
  mimeType      String?

  rowCount      Int?
  columnCount   Int?
  schema        Json?
  schemaDrift   Json?

  status        FileEntryStatus @default(PENDING)
  loadMode      String          @default("APPEND")
  error         String?         @db.Text

  routeLogId    String?
  storagePath   String?

  uploadedAt    DateTime        @default(now())
  processedAt   DateTime?
  uploadedBy    String?
  tenantId      String

  @@index([connectionId, uploadedAt])
  @@index([tenantId])
  @@index([status])
}

enum FileEntryStatus {
  PENDING
  PROCESSING
  LOADED
  SCHEMA_DRIFT
  FAILED
}

// ─── Bifrost Routes ─────────────────────────────────

model BifrostRoute {
  id               String         @id @default(cuid())
  name             String
  enabled          Boolean        @default(true)

  // Source (direct connection OR Raven satellite — mutually exclusive)
  sourceId         String?
  source           Connection?    @relation("routeSource", fields: [sourceId], references: [id], onDelete: Restrict)
  sourceConfig     Json           // { query, dataset, incrementalKey, chunkSize? }

  // Raven (on-prem agent) source — alternative to sourceId
  ravenSatelliteId String?
  ravenSatellite   RavenSatellite? @relation(fields: [ravenSatelliteId], references: [id])

  // Destination
  destId           String
  dest             Connection     @relation("routeDest", fields: [destId], references: [id], onDelete: Restrict)
  destConfig       Json           // { dataset, table, writeDisposition, autoCreateTable, schema? }

  // Optional forge transform
  transformEnabled Boolean        @default(false)
  blueprintId      String?
  blueprint        Blueprint?     @relation(fields: [blueprintId], references: [id], onDelete: SetNull)

  // Embedded schedule
  frequency        String?        // "DAILY", "WEEKLY", "BIWEEKLY", "MONTHLY", "QUARTERLY"
  daysOfWeek       Int[]          @default([])
  dayOfMonth       Int?
  monthsOfYear     Int[]          @default([])
  timeHour         Int            @default(7)
  timeMinute       Int            @default(0)
  timezone         String         @default("America/Chicago")
  nextRunAt        DateTime?
  lastCheckpoint   DateTime?      // Incremental: last successful run timestamp
  cursorConfig     Json?          // CursorConfig: AI-detected cursor strategy (setup-time only)
  needsFullReload  Boolean        @default(false)

  // Ownership
  userId           String
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantId         String?
  tenant           Tenant?        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Relations
  routeLogs        RouteLog[]
  helheimEntries   HelheimEntry[]
  watermarks       PipelineWatermark[]
  forgeBlueprint   ForgeBlueprint? @relation("forgeBlueprint")
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([sourceId])
  @@index([destId])
  @@index([enabled, nextRunAt])
  @@index([tenantId])
}

model RouteLog {
  id               String       @id @default(cuid())
  routeId          String
  route            BifrostRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)
  status           String       // "running", "completed", "partial", "failed"
  rowsExtracted    Int?
  rowsLoaded       Int?
  errorCount       Int          @default(0)
  bytesTransferred BigInt?
  duration         Int?         // milliseconds
  error            String?      @db.Text
  triggeredBy      String       // "schedule", "manual", "webhook"
  startedAt        DateTime     @default(now())
  completedAt      DateTime?

  @@index([routeId, status])
  @@index([routeId, startedAt])
}

model HelheimEntry {
  id            String       @id @default(cuid())
  routeId       String
  route         BifrostRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)
  jobId         String       // RouteLog.id that produced this failure
  chunkIndex    Int
  rowCount      Int
  errorType     String       // "load_failure", "transform_failure", "auth_failure", "timeout"
  errorMessage  String       @db.Text
  errorDetails  Json?        // BQ error response details
  payload       String       @db.Text // base64-encoded gzipped NDJSON
  retryCount    Int          @default(0)
  maxRetries    Int          @default(3)
  nextRetryAt   DateTime?
  status        String       @default("pending") // "pending", "retrying", "recovered", "dead"
  tenantId      String?
  createdAt     DateTime     @default(now())
  lastRetriedAt DateTime?

  @@index([status, nextRetryAt])
  @@index([status, lastRetriedAt])
  @@index([tenantId])
}

// ─── Pipeline Watermarks (Incremental Sync) ─────────

model PipelineWatermark {
  id            String       @id @default(cuid())
  routeId       String
  route         BifrostRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)
  tableName     String
  watermark     String       // serialized: ISO timestamp, integer ID, or hex hash
  watermarkType String       // "timestamp_cursor", "integer_id_cursor", "rowversion_cursor", "full_refresh"
  tenantId      String?
  rowsSynced    Int?
  runAt         DateTime     @default(now())

  @@unique([routeId, tableName])
  @@index([routeId])
  @@index([tenantId])
}

// ─── Alfheim (API Catalog) ──────────────────────────

enum ApiAuthType {
  API_KEY
  BEARER
  BASIC
  OAUTH2
  CUSTOM
}

model ApiCatalogConnector {
  id            String        @id @default(cuid())
  slug          String        @unique
  name          String
  description   String
  category      String
  subcategory   String?
  logoUrl       String?
  docsUrl       String?
  popularity    Int           @default(0)
  enabled       Boolean       @default(true)
  authType      ApiAuthType
  baseUrl       String
  authConfig    Json
  pagination    Json
  rateLimiting  Json?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  createdBy     String?
  objects       ApiCatalogObject[]

  @@index([category])
  @@index([enabled])
}

model ApiCatalogObject {
  id              String               @id @default(cuid())
  connectorId     String
  connector       ApiCatalogConnector   @relation(fields: [connectorId], references: [id], onDelete: Cascade)
  slug            String
  name            String
  description     String?
  endpoint        String
  method          String               @default("GET")
  responseRoot    String
  incrementalKey  String?
  defaultParams   Json?
  schema          Json

  @@unique([connectorId, slug])
}

// ─── Raven (On-Prem Data Agents) ────────────────────

model RavenApiKey {
  id          String    @id @default(uuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  keyHash     String    @unique    // bcrypt hash of the full API key
  keyPrefix   String               // First 8 chars for display: "hrv_a1b2..."
  name        String               // Human-friendly: "Production Raven Key"
  scopes      String[]  @default(["raven:read", "raven:push"])
  status      String    @default("active")  // active | revoked
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([tenantId])
  @@index([keyHash])
}

model RavenSatellite {
  id                String    @id @default(uuid())
  tenantId          String
  tenant            Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name              String    // "Pinnacle Shop Floor", "HQ SQL Server"
  apiKeyHash        String    // Hash of the API key used to register (links to RavenApiKey.keyHash)
  status            String    @default("pending")  // pending | active | disconnected | revoked
  version           String?
  hostname          String?
  platform          String?
  lastHeartbeatAt   DateTime?
  metadata          Json?     // Latest heartbeat payload (uptime, memory, cpu, etc.)
  connections       Json?     // Connection summaries: [{id, name, driver, database, status}]
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  jobs              RavenJob[]
  routes            BifrostRoute[]

  @@index([tenantId])
  @@index([status])
  @@index([apiKeyHash])
}

model RavenJob {
  id              String          @id @default(uuid())
  ravenId         String
  raven           RavenSatellite  @relation(fields: [ravenId], references: [id], onDelete: Cascade)
  routeId         String?         // Optional link to a Bifrost route that created this job
  routeLogId      String?         // RouteLog ID for pipeline resumption
  connectionId    String          // Raven-local connection ID (matches DatabaseConnection.id on the Raven)
  query           String          @db.Text
  queryParams     Json?
  schedule        String?         // Cron expression for recurring jobs
  destination     Json            // { type: "hermod_cloud" | "direct_push", endpoint?, table?, mode: "append" | "replace" }
  timeout         Int             @default(120)   // Query timeout in seconds
  maxRows         Int?            // Safety valve row limit
  priority        Int             @default(3)     // 1 = highest, 5 = lowest
  status          String          @default("pending")  // pending | claimed | running | success | error | partial
  claimedAt       DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  result          Json?           // { rowCount, byteSize, durationMs, error?, chunks }
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  ingestChunks    RavenIngestChunk[]

  @@index([ravenId, status])
  @@index([status])
  @@index([createdAt])
  @@index([connectionId])
}

model RavenIngestChunk {
  id            String    @id @default(uuid())
  jobId         String
  job           RavenJob  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  chunkIndex    Int
  totalChunks   Int
  data          Json      @db.JsonB
  receivedAt    DateTime  @default(now())

  @@unique([jobId, chunkIndex])
  @@index([jobId])
}

// ─── Realm Gates ────────────────────────────────────

model RealmGate {
  id                String           @id @default(cuid())
  tenantId          String
  tenant            Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name              String

  realmType         String           // "VANAHEIM" (Excel) or "JOTUNHEIM" (CSV/TSV)

  // Destination (always Asgard — a database connection)
  connectionId      String
  connection        Connection       @relation(fields: [connectionId], references: [id])
  targetTable       String           // e.g. "Customers"
  targetSchema      String?          // e.g. "dbo" — nullable for databases that don't use schemas

  // Mapping & Strategy
  primaryKeyColumns Json             @default("[]") // Array of source column names — e.g. ["PO Number", "ISBN"]
  mergeStrategy     String           // "UPSERT" | "TRUNCATE_RELOAD" | "APPEND"
  columnMapping     Json             // Array of { sourceColumn, destinationColumn, sourceType, destType }
  savedSchema       Json             // DuckDB-profiled schema snapshot from initial setup file (drift detection)

  // Optional Forge
  forgeEnabled      Boolean          @default(false)
  forgeBlueprintId  String?
  forgeBlueprint    ForgeBlueprint?  @relation(fields: [forgeBlueprintId], references: [id], onDelete: SetNull)

  // Metadata
  status            String           @default("ACTIVE") // "ACTIVE" | "PAUSED" | "ARCHIVED"
  lastPushAt        DateTime?
  pushCount         Int              @default(0)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  pushes            GatePush[]

  @@index([tenantId])
  @@index([tenantId, status])
}

model GatePush {
  id              String    @id @default(cuid())
  gateId          String
  gate            RealmGate @relation(fields: [gateId], references: [id], onDelete: Cascade)
  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // File info
  fileName        String
  fileSize        Int       // bytes
  fileMimeType    String?

  // Execution
  status          String    // "VALIDATING" | "VALIDATED" | "SCHEMA_DRIFT" | "PUSHING" | "SUCCESS" | "FAILED" | "CANCELLED"
  rowCount        Int?
  rowsInserted    Int?
  rowsUpdated     Int?
  rowsErrored     Int?

  // Schema drift details
  schemaDiff      Json?     // { added: [], removed: [], typeChanged: [] }
  driftResolution String?   // "ADJUSTED_FILE" | "ADJUSTED_DESTINATION" | null

  // Error handling
  errorMessage    String?
  errorDetails    Json?     // stack trace, row-level errors, etc.

  // Temp file reference (for schema drift re-push)
  tempFileId      String?

  // Timing
  duration        Int?      // milliseconds
  createdAt       DateTime  @default(now())
  completedAt     DateTime?

  @@index([gateId])
  @@index([tenantId])
  @@index([tenantId, createdAt(sort: Desc)])
}
